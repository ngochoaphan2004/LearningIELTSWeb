generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  avatar_url    String?
  current_level   Float?
  target_score    Float?
  current_streak  Int       @default(0)
  max_streak      Int       @default(0)
  last_study_date DateTime?

  userCourses    UserCourse[]
  feedActivities FeedActivity[]
  sessionProgress UserSessionProgress[]
  vocabularyNotes VocabularyNote[]
  errorLogs       ErrorLog[]
  dictationNotes  DictationNote[]
}

model Course {
  id               String   @id @default(uuid())
  title            String
  description      String?
  total_days       Int
  focus_skill      String?
  total_duration   String?
  thumbnail_url    String?

  userCourses      UserCourse[]
  sessions         StudySession[]
}

model UserCourse {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED
  enrolled_at DateTime @default(now())

  @@unique([userId, courseId])
}

model StudySession {
  id                   String   @id @default(uuid())
  courseId             String
  course               Course   @relation(fields: [courseId], references: [id])
  title                String
  day_number           Int
  week_number          Int?
  focus_skill          String?
  activity_description String
  duration_minutes     Int      @default(60)
  reference_pdfs       String[] // Array of PDF files
  embedded_url         String?  // Link URL to embed data


  userProgress         UserSessionProgress[]
  vocabularyNotes      VocabularyNote[]
  errorLogs            ErrorLog[]
  dictationNotes       DictationNote[]
}

model UserSessionProgress {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  sessionId      String
  session        StudySession @relation(fields: [sessionId], references: [id])
  status         String       // Status: LOCKED, IN_PROGRESS, COMPLETED, MISSED
  scheduled_date DateTime
  started_at     DateTime?
  completed_at   DateTime?
}

model FeedActivity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action_type String
  content     String
  created_at  DateTime @default(now())
}

model VocabularyNote {
  id                 String       @id @default(uuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  sessionId          String
  session            StudySession @relation(fields: [sessionId], references: [id])
  
  phrase             String
  meaning            String
  example_sentence   String?
  errors_in_sentence String?
  
  created_at         DateTime     @default(now())
}

model ErrorLog {
  id                 String       @id @default(uuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  sessionId          String
  session            StudySession @relation(fields: [sessionId], references: [id])
  
  content_submitted  String
  errors_found       String?
  
  created_at         DateTime     @default(now())
}

model DictationNote {
  id                 String       @id @default(uuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id])
  sessionId          String
  session            StudySession @relation(fields: [sessionId], references: [id])
  
  audio_link         String
  dictation_text     String
  
  created_at         DateTime     @default(now())
}
